<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.CadastroPartidaController"
            prefWidth="900"
            prefHeight="580"
            styleClass="root">

    <VBox alignment="TOP_CENTER"
          spacing="20"
          AnchorPane.topAnchor="20"
          AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20">

        <ImageView fitWidth="70" fitHeight="70" preserveRatio="true">
            <image><Image url="@/images/worldcup_logo.png"/></image>
        </ImageView>

        <VBox spacing="16" styleClass="card">

            <Label text="Cadastro de Partida" styleClass="titulo"/>

            <GridPane hgap="15" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <!-- Time da Casa -->
                <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <Label text="Time da casa" styleClass="label"/>
                    <ComboBox fx:id="comboTimeCasa"
                              promptText="Selecione o time da casa"
                              maxWidth="Infinity"/>
                </VBox>

                <!-- Time Visitante -->
                <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <Label text="Time visitante" styleClass="label"/>
                    <ComboBox fx:id="comboTimeVisitante"
                              promptText="Selecione o time visitante"
                              maxWidth="Infinity"/>
                </VBox>

                <!-- Estádio -->
                <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="0">
                    <Label text="Estádio" styleClass="label"/>
                    <ComboBox fx:id="comboEstadio"
                              promptText="Selecione o estádio"
                              maxWidth="Infinity"/>
                </VBox>

                <!-- Fase -->
                <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <Label text="Fase" styleClass="label"/>
                    <ComboBox fx:id="comboFase"
                              promptText="Selecione a fase"
                              maxWidth="Infinity"/>
                </VBox>

                <!-- Data — DatePicker com calendário visual -->
                <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="0">
                    <Label text="Data" styleClass="label"/>
                    <DatePicker fx:id="campoData"
                                promptText="Selecione a data"
                                maxWidth="Infinity"/>
                </VBox>

                <!-- Horário -->
                <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <Label text="Horário (hh:mm)" styleClass="label"/>
                    <TextField fx:id="campoHorario" promptText="Ex: 16:00"/>
                </VBox>

            </GridPane>

            <!-- Botões -->
            <HBox spacing="12">
                <Button text="Salvar"  onAction="#aoSalvar"  styleClass="btn-cadastrar"/>
                <Button text="Voltar"  onAction="#aoVoltar"  styleClass="btn-voltar"/>
            </HBox>

            <Label fx:id="labelFeedback"/>

        </VBox>
    </VBox>

    <stylesheets>
        <String fx:value="/css/cadastro_partida.css"/>
    </stylesheets>

</AnchorPane>
