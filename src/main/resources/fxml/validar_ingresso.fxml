<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.ValidarIngressoController"
            style="-fx-background-color: #0a0a0a;">

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d0d0d;
                     -fx-padding: 0 24 0 16;
                     -fx-min-height: 56;
                     -fx-border-color: transparent transparent #1e1a0a transparent;
                     -fx-border-width: 0 0 1 0;">

            <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                <image><Image url="@../images/worldcup_logo.png"/></image>
            </ImageView>

            <Region HBox.hgrow="NEVER" minWidth="20"/>
            <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelUsuarioLogado"
                   style="-fx-text-fill: #b0a898;
                          -fx-font-size: 12;
                          -fx-font-family: 'Segoe UI';"/>
            <Region minWidth="16"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #c9982a;
                           -fx-text-fill: #0a0a0a;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-font-family: 'Segoe UI';
                           -fx-background-radius: 14;
                           -fx-padding: 6 18 6 18;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CONTEÚDO ===== -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="32"
              style="-fx-background-color: radial-gradient(center 50% 60%, radius 70%, #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);">

            <padding>
                <Insets top="50" right="40" bottom="40" left="40"/>
            </padding>

            <Label text="Validar Ingresso" styleClass="sel-titulo-v3"/>

            <Label text="Insira o número do ingresso para registrar a entrada no estádio."
                   styleClass="setor-info"
                   wrapText="true"/>

            <!-- PAINEL DE BUSCA -->
            <VBox alignment="CENTER" spacing="16" maxWidth="500">

                <Label text="Número do Ingresso" styleClass="setor-info"/>

                <HBox spacing="12" alignment="CENTER">
                    <TextField fx:id="campoIdIngresso"
                               promptText="Ex: 42"
                               prefWidth="260"
                               prefHeight="42"
                               styleClass="campo-texto"/>
                    <Button text="Validar Entrada"
                            onAction="#aoValidar"
                            styleClass="sel-btn-cadastro-v3"
                            prefHeight="42"
                            prefWidth="160"/>
                    <Button text="Limpar"
                            onAction="#aoLimpar"
                            styleClass="sel-btn-consulta-v3"
                            prefHeight="42"/>
                </HBox>

            </VBox>

            <!-- PAINEL DE RESULTADO -->
            <VBox fx:id="painelResultado"
                  alignment="CENTER"
                  spacing="10"
                  maxWidth="500"
                  style="-fx-background-color: rgba(20, 16, 8, 0.90);
                         -fx-background-radius: 14;
                         -fx-border-color: #3a3020;
                         -fx-border-radius: 14;
                         -fx-border-width: 1;
                         -fx-padding: 24;">

                <Label fx:id="labelResultado"
                       text=""
                       wrapText="true"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

                <Label fx:id="labelDetalhe"
                       text=""
                       wrapText="true"
                       styleClass="setor-info"/>

            </VBox>

        </VBox>
    </center>

    <stylesheets>
        <String fx:value="/css/menu.css"/>
        <String fx:value="/css/selecao_inicio.css"/>
        <String fx:value="/css/ingressos.css"/>
        <String fx:value="/css/validar_ingresso.css"/>
    </stylesheets>

</BorderPane>
