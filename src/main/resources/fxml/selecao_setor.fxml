<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllersJavaFX.SelecaoSetorController"
      prefWidth="1200"
      prefHeight="700"
      styleClass="sel-root-v3">

    <style>
        -fx-background-color: radial-gradient(center 50% 60%, radius 70%,
        #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);
    </style>

    <!-- ===== NAVBAR ===== -->

    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #0d0d0d;
                 -fx-padding: 0 24 0 16;
                 -fx-min-height: 56;
                 -fx-border-color: transparent transparent #1e1a0a transparent;
                 -fx-border-width: 0 0 1 0;">

        <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
            <image><Image url="@/images/worldcup_logo.png"/></image>
        </ImageView>

        <Region HBox.hgrow="NEVER" minWidth="20"/>
        <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label fx:id="labelUsuarioLogado"
               style="-fx-text-fill: #b0a898;
                      -fx-font-size: 12;
                      -fx-font-family: 'Segoe UI';"/>
        <Region minWidth="16"/>
        <Button text="Sair" onAction="#handleLogout"
                style="-fx-background-color: #c9982a;
                       -fx-text-fill: #0a0a0a;
                       -fx-font-weight: bold;
                       -fx-font-size: 12;
                       -fx-font-family: 'Segoe UI';
                       -fx-background-radius: 14;
                       -fx-padding: 6 18 6 18;
                       -fx-cursor: hand;"/>
    </HBox>

    <!-- CORPO -->

    <HBox VBox.vgrow="ALWAYS"
          spacing="24"
          alignment="TOP_LEFT">

        <padding>
            <Insets top="30"
                    right="40"
                    bottom="30"
                    left="40"/>
        </padding>

        <!-- CARD DA PARTIDA -->

        <VBox styleClass="setor-card-partida"
              spacing="16"
              alignment="TOP_LEFT"
              prefWidth="280"
              minWidth="280">

            <HBox fx:id="painelBandeiras"
                  styleClass="setor-bandeiras"
                  alignment="CENTER"
                  spacing="0">

                <!-- bandeiras das selecoes inseridas dinamicamente -->

            </HBox>

            <Label fx:id="labelConfronto"
                   text="Seleção x Seleção"
                   styleClass="setor-confronto"
                   wrapText="true"/>

            <Label fx:id="labelData"
                   text="00/00/0000"
                   styleClass="setor-info"/>

            <Label fx:id="labelHorario"
                   text="00h"
                   styleClass="setor-info"/>

        </VBox>

        <!-- LISTA DE SETORES -->

        <VBox styleClass="setor-card-lista"
              spacing="12"
              HBox.hgrow="ALWAYS"
              prefWidth="380"
              minWidth="320">

            <Label text="Selecione um setor"
                   styleClass="setor-titulo-secao"/>

            <ScrollPane fitToWidth="true"
                        styleClass="setor-scroll"
                        VBox.vgrow="ALWAYS">

                <VBox fx:id="painelSetores"
                      spacing="14">

                    <!-- itens de setor inseridos dinamicamente -->

                </VBox>

            </ScrollPane>

        </VBox>

        <!-- MAPA DE SETORES -->

        <VBox styleClass="setor-card-mapa"
              alignment="TOP_CENTER"
              spacing="16"
              prefWidth="380"
              minWidth="320"
              HBox.hgrow="ALWAYS">

            <StackPane styleClass="setor-mapa-placeholder"
                       prefWidth="320"
                       prefHeight="220"
                       minHeight="220">

                <Label text="🏟"
                       styleClass="setor-mapa-icone"/>

                <Label text="Mapa do estádio"
                       styleClass="setor-mapa-legenda"
                       StackPane.alignment="BOTTOM_CENTER">
                    <StackPane.margin>
                        <Insets bottom="12"/>
                    </StackPane.margin>
                </Label>

            </StackPane>

            <FlowPane fx:id="painelLegenda"
                      hgap="14"
                      vgap="8"
                      alignment="CENTER"
                      styleClass="setor-legenda">

                <!-- itens de legenda inseridos dinamicamente pelo SelecaoSetorController -->

            </FlowPane>

        </VBox>

    </HBox>

    <stylesheets>
        <String fx:value="/css/selecao_inicio.css"/>
        <String fx:value="/css/ingressos.css"/>
    </stylesheets>

</VBox>
