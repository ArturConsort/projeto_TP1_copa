<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.RelatoriosController"
            style="-fx-background-color: #0a0a0a;">

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d0d0d;
                     -fx-padding: 0 24 0 16;
                     -fx-min-height: 56;
                     -fx-border-color: transparent transparent #1e1a0a transparent;
                     -fx-border-width: 0 0 1 0;">

            <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                <image><Image url="@../images/worldcup_logo.png"/></image>
            </ImageView>

            <Region HBox.hgrow="NEVER" minWidth="20"/>
            <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelUsuarioLogado"
                   style="-fx-text-fill: #b0a898;
                          -fx-font-size: 12;
                          -fx-font-family: 'Segoe UI';"/>
            <Region minWidth="16"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #c9982a;
                           -fx-text-fill: #0a0a0a;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-font-family: 'Segoe UI';
                           -fx-background-radius: 14;
                           -fx-padding: 6 18 6 18;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CONTEÚDO ===== -->
    <center>
        <VBox spacing="0"
              style="-fx-background-color: #0a0a0a;
                     -fx-padding: 28 32 28 32;">

            <!-- Título -->
            <Label text="Relatórios"
                   style="-fx-text-fill: #c9982a;
                          -fx-font-size: 22;
                          -fx-font-weight: bold;
                          -fx-font-family: 'Segoe UI';
                          -fx-alignment: center;
                          -fx-padding: 0 0 20 0;"/>

            <!-- Botões de tipo de relatório -->
            <HBox spacing="10" style="-fx-padding: 0 0 20 0;">
                <Button fx:id="btnUsuarios"
                        text="Usuários"
                        onAction="#handleRelatorioUsuarios"
                        styleClass="btn-relatorio-ativo"/>
                <Button fx:id="btnPartidas"
                        text="Partidas"
                        onAction="#handleRelatorioPartidas"
                        styleClass="btn-relatorio"/>
                <Button fx:id="btnVendas"
                        text="Vendas de Ingressos"
                        onAction="#handleRelatorioVendas"
                        styleClass="btn-relatorio"/>
            </HBox>

            <!-- Terminal -->
            <VBox VBox.vgrow="ALWAYS" styleClass="terminal-container" spacing="0">

                <!-- Barra superior do terminal (macOS style) -->
                <HBox styleClass="terminal-topbar" alignment="CENTER_LEFT" spacing="6">
                    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

                    <!-- Dots -->
                    <Label text="●" style="-fx-text-fill: #ff5f57; -fx-font-size: 11;"/>
                    <Label text="●" style="-fx-text-fill: #febc2e; -fx-font-size: 11;"/>
                    <Label text="●" style="-fx-text-fill: #28c840; -fx-font-size: 11;"/>

                    <Region HBox.hgrow="NEVER" minWidth="8"/>

                    <Label fx:id="labelTitulo"
                           text="relatório - usuários"
                           style="-fx-text-fill: #8a7e64;
                                  -fx-font-size: 12;
                                  -fx-font-family: 'Consolas', 'Courier New', monospace;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="gerar arquivo"
                            onAction="#handleGerarArquivo"
                            styleClass="btn-limpar-terminal"/>
                    <Button text="limpar"
                            onAction="#handleLimpar"
                            styleClass="btn-limpar-terminal"/>
                </HBox>

                <!-- Área de texto do terminal -->
                <TextArea fx:id="terminalOutput"
                          editable="false"
                          wrapText="false"
                          VBox.vgrow="ALWAYS"
                          styleClass="terminal-output"/>
            </VBox>

        </VBox>
    </center>

    <stylesheets>
        <String fx:value="/css/menu.css"/>
        <String fx:value="/css/relatorios.css"/>
    </stylesheets>

</BorderPane>
