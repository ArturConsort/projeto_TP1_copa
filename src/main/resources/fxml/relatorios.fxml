<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<?import java.lang.String?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.RelatoriosController">

    <style>
        -fx-background-color: radial-gradient(center 50% 60%, radius 70%,
        #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);
    </style>

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d0d0d; -fx-padding: 0 24 0 16; -fx-min-height: 56;">
            <ImageView fitWidth="48" fitHeight="48" preserveRatio="true">
                <image><Image url="@../images/worldcup_logo.png"/></image>
            </ImageView>
            <Region HBox.hgrow="NEVER" minWidth="24"/>
            <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelUsuarioLogado"
                   style="-fx-text-fill: #b0a898; -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
            <Region minWidth="16"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #c9982a; -fx-text-fill: #0a0a0a;
                           -fx-font-weight: bold; -fx-font-size: 12;
                           -fx-font-family: 'Segoe UI'; -fx-background-radius: 14;
                           -fx-padding: 6 18 6 18; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CONTEÚDO ===== -->
    <center>
        <VBox spacing="20" style="-fx-padding: 36 60 36 60;" alignment="TOP_CENTER">

            <!-- Título -->
            <Label text="Relatórios"
                   style="-fx-text-fill: #c9982a; -fx-font-size: 22;
                          -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

            <!-- Botões de tipo de relatório -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="Usuários" onAction="#handleRelatorioUsuarios"
                        styleClass="btn-relatorio-ativo" fx:id="btnRelUsuarios"/>
            </HBox>

            <!-- Card do painel de log -->
            <VBox VBox.vgrow="ALWAYS" spacing="0"
                  style="-fx-background-color: #0f0f0f;
                         -fx-background-radius: 10;
                         -fx-border-color: #2e2a1a;
                         -fx-border-radius: 10;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 16, 0, 0, 4);">

                <!-- Barra de título do terminal -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color: #1a1608;
                             -fx-background-radius: 10 10 0 0;
                             -fx-border-color: transparent transparent #2e2a1a transparent;
                             -fx-padding: 10 16 10 16;">

                    <!-- Bolinhas decorativas estilo terminal -->
                    <Pane style="-fx-background-color: #ff5f57; -fx-background-radius: 50;
                                 -fx-min-width: 12; -fx-min-height: 12;
                                 -fx-max-width: 12; -fx-max-height: 12;"/>
                    <Pane style="-fx-background-color: #febc2e; -fx-background-radius: 50;
                                 -fx-min-width: 12; -fx-min-height: 12;
                                 -fx-max-width: 12; -fx-max-height: 12;"/>
                    <Pane style="-fx-background-color: #28c840; -fx-background-radius: 50;
                                 -fx-min-width: 12; -fx-min-height: 12;
                                 -fx-max-width: 12; -fx-max-height: 12;"/>

                    <Region HBox.hgrow="NEVER" minWidth="8"/>
                    <Label fx:id="labelTituloRelatorio" text="relatório · usuários"
                           style="-fx-text-fill: #6a6050; -fx-font-size: 12;
                                  -fx-font-family: 'Consolas';"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Botão limpar -->
                    <Button text="limpar" onAction="#handleLimpar"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #4a4030;
                                   -fx-font-size: 11;
                                   -fx-font-family: 'Consolas';
                                   -fx-cursor: hand;
                                   -fx-border-color: #2e2a1a;
                                   -fx-border-radius: 4;
                                   -fx-background-radius: 4;
                                   -fx-padding: 3 10 3 10;"/>
                </HBox>

                <!-- Área de texto com scroll -->
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                            style="-fx-background-color: transparent;
                                   -fx-background: transparent;
                                   -fx-border-color: transparent;
                                   -fx-padding: 0;">
                    <TextArea fx:id="areaRelatorio"
                              editable="false"
                              wrapText="true"
                              style="-fx-background-color: transparent;
                                     -fx-control-inner-background: #0f0f0f;
                                     -fx-text-fill: #c8c0a8;
                                     -fx-font-family: 'Consolas';
                                     -fx-font-size: 13;
                                     -fx-padding: 20 24 20 24;
                                     -fx-border-color: transparent;
                                     -fx-background-radius: 0 0 10 10;
                                     -fx-highlight-fill: #3a2e0a;
                                     -fx-highlight-text-fill: #e8e0cc;"/>
                </ScrollPane>

            </VBox>

        </VBox>
    </center>

    <stylesheets>
        <String fx:value="/css/menu.css"/>
        <String fx:value="/css/relatorios.css"/>
    </stylesheets>

</BorderPane>
