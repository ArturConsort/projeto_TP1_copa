<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.ConsultaSelecaoController"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: radial-gradient(center 50% 60%, radius 70%, #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);">

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d0d0d;
                     -fx-padding: 0 24 0 16;
                     -fx-min-height: 56;
                     -fx-border-color: transparent transparent #1e1a0a transparent;
                     -fx-border-width: 0 0 1 0;">

            <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                <image><Image url="@../images/worldcup_logo.png"/></image>
            </ImageView>

            <Region HBox.hgrow="NEVER" minWidth="20"/>
            <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelUsuarioLogado"
                   style="-fx-text-fill: #b0a898;
                          -fx-font-size: 12;
                          -fx-font-family: 'Segoe UI';"/>
            <Region minWidth="16"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #c9982a;
                           -fx-text-fill: #0a0a0a;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-font-family: 'Segoe UI';
                           -fx-background-radius: 14;
                           -fx-padding: 6 18 6 18;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CORPO ===== -->
    <center>
        <VBox spacing="20" alignment="TOP_CENTER">

            <padding>
                <Insets top="30" right="40" bottom="20" left="40"/>
            </padding>

            <Label text="Consulta de Seleções" styleClass="sel-titulo-v3"/>

            <!-- FILTROS -->
            <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filtro-box">

                <Label text="País"/>
                <TextField fx:id="campoPais" promptText="Nome da seleção" prefWidth="220"/>

                <Label text="Grupo"/>
                <ComboBox fx:id="comboGrupo" promptText="Grupo" prefWidth="120"/>

                <Label text="Técnico"/>
                <TextField fx:id="campoTecnico" promptText="Técnico" prefWidth="250"/>

                <Button text="Pesquisar" onAction="#handlePesquisar" styleClass="sel-btn-cadastro-v3"/>
                <Button text="Limpar"    onAction="#handleLimpar"    styleClass="sel-btn-consulta-v3"/>
                <Button text="Editar"    onAction="#handleEditar"    styleClass="sel-btn-cadastro-v3"/>
                <Button text="Excluir"   onAction="#handleExcluir"   styleClass="btn-excluir"/>

            </HBox>

            <!-- TABELA -->
            <TableView fx:id="tabelaSelecoes" VBox.vgrow="ALWAYS" styleClass="tabela-selecoes">
                <columns>
                    <TableColumn fx:id="colPais"    text="País"         prefWidth="280"/>
                    <TableColumn fx:id="colGrupo"   text="Grupo"        prefWidth="120"/>
                    <TableColumn fx:id="colTecnico" text="Técnico"      prefWidth="280"/>
                    <TableColumn fx:id="colRanking" text="Ranking FIFA" prefWidth="160"/>
                    <TableColumn fx:id="colTitulos" text="Títulos"      prefWidth="120"/>
                </columns>
            </TableView>

            <!-- RODAPÉ -->
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <Label fx:id="labelTotal"/>
            </HBox>

        </VBox>
    </center>

    <stylesheets>
        <String fx:value="/css/menu.css"/>
        <String fx:value="/css/selecao_inicio.css"/>
        <String fx:value="/css/consulta_selecao.css"/>
    </stylesheets>

</BorderPane>
