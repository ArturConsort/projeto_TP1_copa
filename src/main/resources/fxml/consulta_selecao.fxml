<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllersJavaFX.ConsultaSelecaoController"
      prefWidth="1200"
      prefHeight="700"
      styleClass="sel-root-v3">

    <style>
        -fx-background-color: radial-gradient(center 50% 60%, radius 70%,
        #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);
    </style>

    <!-- HUD -->

    <HBox styleClass="hud-bar" alignment="CENTER_LEFT">

        <ImageView fitHeight="48"
                   fitWidth="48"
                   preserveRatio="true">
            <image>
                <Image url="@/images/worldcup_logo.png"/>
            </image>

            <HBox.margin>
                <Insets right="24"/>
            </HBox.margin>
        </ImageView>

        <Button fx:id="btnHome"      text="Home"      onAction="#irHome"      styleClass="nav-btn"/>
        <Button fx:id="btnJogadores" text="Jogadores" onAction="#irJogadores" styleClass="nav-btn"/>
        <Button fx:id="btnEquipes"   text="Equipes"   onAction="#irEquipes"   styleClass="nav-btn"/>  <!-- ← ativo -->
        <Button fx:id="btnPartidas"  text="Partidas"  onAction="#irPartidas"  styleClass="nav-btn"/>
        <Button fx:id="btnEstadios"  text="Estádios"  onAction="#irEstadios"  styleClass="nav-btn"/>
        <Button fx:id="btnArbitros"  text="Árbitros"  onAction="#irArbitros"  styleClass="nav-btn"/>
        <Button fx:id="btnIngressos" text="Ingressos" onAction="#irIngressos" styleClass="nav-btn"/>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox styleClass="hud-search-v3"
              alignment="CENTER_LEFT"
              spacing="6">

            <padding>
                <Insets top="0"
                        right="12"
                        bottom="0"
                        left="10"/>
            </padding>

        </HBox>

    </HBox>

    <!-- CORPO -->

    <VBox VBox.vgrow="ALWAYS"
          spacing="20"
          alignment="TOP_CENTER">

        <padding>
            <Insets top="30"
                    right="40"
                    bottom="20"
                    left="40"/>
        </padding>

        <Label text="Consulta de Seleções"
               styleClass="sel-titulo-v3"/>

        <!-- FILTROS -->

        <HBox spacing="15"
              alignment="CENTER_LEFT"
              styleClass="filtro-box">

            <Label text="País"/>

            <TextField fx:id="campoPais"
                       promptText="Nome da seleção"
                       prefWidth="220"/>


            <Label text="Grupo"/>

            <ComboBox fx:id="comboGrupo"
                      promptText="Grupo"
                      prefWidth="120"/>

            <Label text="Técnico"/>

            <TextField fx:id="campoTecnico"
                       promptText="Técnico"
                       prefWidth="250"/>

            <Button text="Pesquisar"
                    onAction="#handlePesquisar"
                    styleClass="sel-btn-cadastro-v3"/>

            <Button text="Limpar"
                    onAction="#handleLimpar"
                    styleClass="sel-btn-consulta-v3"/>

            <Button text="Editar"
                    onAction="#handleEditar"
                    styleClass="sel-btn-cadastro-v3"/>

            <Button text="Excluir"
                    onAction="#handleExcluir"
                    styleClass="btn-excluir"/>

        </HBox>

        <!-- TABELA -->

        <TableView fx:id="tabelaSelecoes"
                   VBox.vgrow="ALWAYS"
                   styleClass="tabela-selecoes">

            <columns>

                <TableColumn fx:id="colPais"
                             text="País"
                             prefWidth="280"/>

                <TableColumn fx:id="colGrupo"
                             text="Grupo"
                             prefWidth="120"/>

                <TableColumn fx:id="colTecnico"
                             text="Técnico"
                             prefWidth="280"/>

                <TableColumn fx:id="colRanking"
                             text="Ranking FIFA"
                             prefWidth="160"/>

                <TableColumn fx:id="colTitulos"
                             text="Títulos"
                             prefWidth="120"/>

            </columns>

        </TableView>

        <!-- RODAPÉ -->

        <HBox alignment="CENTER_RIGHT"
              spacing="15">

            <Label fx:id="labelTotal"/>


        </HBox>

    </VBox>

    <stylesheets>
        <String fx:value="/css/selecao_inicio.css"/>
        <String fx:value="/css/consulta_selecao.css"/>
    </stylesheets>

</VBox>