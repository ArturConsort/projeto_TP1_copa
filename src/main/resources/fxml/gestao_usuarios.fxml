<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<?import java.lang.String?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.GestaoUsuariosController">

    <!-- fundo -->
    <style>
        -fx-background-color: radial-gradient(center 50% 60%, radius 70%,
        #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);
    </style>

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d0d0d; -fx-padding: 0 24 0 16; -fx-min-height: 56;">
            <ImageView fitWidth="48" fitHeight="48" preserveRatio="true">
                <image><Image url="@../images/worldcup_logo.png"/></image>
            </ImageView>
            <Region HBox.hgrow="NEVER" minWidth="24"/>
            <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelUsuarioLogado"
                   style="-fx-text-fill: #b0a898; -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
            <Region minWidth="16"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #c9982a; -fx-text-fill: #0a0a0a;
                           -fx-font-weight: bold; -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                           -fx-background-radius: 14; -fx-padding: 6 18 6 18; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CONTEÚDO ===== -->
    <center>
        <HBox style="-fx-padding: 40 40 40 40;" spacing="0">

            <!-- Coluna esquerda: filtros + lista -->
            <VBox spacing="0" minWidth="260" maxWidth="260"
                  style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 12, 0, 2, 2);">

                <!-- Painel de filtros -->
                <VBox spacing="8"
                      style="-fx-background-color: #e8e8e3;
                             -fx-background-radius: 8 0 0 0;
                             -fx-border-color: transparent transparent #ccccbb transparent;
                             -fx-padding: 12 12 12 12;">

                    <TextField fx:id="campoBuscaNome"
                               promptText="Buscar por nome..."
                               onKeyReleased="#handleFiltrar"
                               style="-fx-background-color: #ffffff;
                                      -fx-border-color: #ccccbb;
                                      -fx-border-radius: 6;
                                      -fx-background-radius: 6;
                                      -fx-padding: 7 10 7 10;
                                      -fx-font-size: 12;
                                      -fx-font-family: 'Segoe UI';
                                      -fx-text-fill: #333;
                                      -fx-prompt-text-fill: #999;"/>

                    <TextField fx:id="campoBuscaPais"
                               promptText="Buscar por país..."
                               onKeyReleased="#handleFiltrar"
                               style="-fx-background-color: #ffffff;
                                      -fx-border-color: #ccccbb;
                                      -fx-border-radius: 6;
                                      -fx-background-radius: 6;
                                      -fx-padding: 7 10 7 10;
                                      -fx-font-size: 12;
                                      -fx-font-family: 'Segoe UI';
                                      -fx-text-fill: #333;
                                      -fx-prompt-text-fill: #999;"/>

                    <ComboBox fx:id="comboBuscaPerfil"
                              promptText="Filtrar por perfil..."
                              onAction="#handleFiltrar"
                              maxWidth="Infinity"
                              style="-fx-background-color: #ffffff;
                                     -fx-border-color: #ccccbb;
                                     -fx-border-radius: 6;
                                     -fx-background-radius: 6;
                                     -fx-font-size: 12;
                                     -fx-font-family: 'Segoe UI';"/>
                </VBox>

                <!-- Lista de nomes -->
                <ListView fx:id="listaUsuarios" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #f5f5f0;
                                 -fx-border-color: transparent;
                                 -fx-background-radius: 0 0 0 8;
                                 -fx-padding: 0;"/>
            </VBox>

            <!-- Painel de ações — aparece ao selecionar um usuário -->
            <VBox fx:id="painelAcoes" spacing="0" minWidth="180"
                  visible="false" managed="false"
                  style="-fx-background-color: #ffffff;
                         -fx-border-color: #ddddcc;
                         -fx-border-width: 0 0 0 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 2, 0);">

                <!-- Nome do selecionado como cabeçalho -->
                <Label fx:id="labelNomeSelecionado" text=""
                       style="-fx-background-color: #c9982a;
                              -fx-text-fill: #0a0a0a;
                              -fx-font-weight: bold;
                              -fx-font-size: 13;
                              -fx-font-family: 'Segoe UI';
                              -fx-padding: 12 16 12 16;
                              -fx-pref-width: Infinity;"/>

                <Button text="Remover usuário" onAction="#handleRemover"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #222;
                               -fx-font-size: 13;
                               -fx-font-family: 'Segoe UI';
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 11 16 11 16;
                               -fx-pref-width: Infinity;
                               -fx-border-color: transparent transparent #eee transparent;
                               -fx-cursor: hand;"/>

                <!-- Editar acesso — abre submenu com perfis -->
                <Button fx:id="btnEditarAcesso" text="Editar acesso  ›"
                        onAction="#handleAbrirSubmenuPerfil"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #222;
                               -fx-font-size: 13;
                               -fx-font-family: 'Segoe UI';
                               -fx-alignment: CENTER_LEFT;
                               -fx-padding: 11 16 11 16;
                               -fx-pref-width: Infinity;
                               -fx-cursor: hand;"/>
            </VBox>

            <!-- Submenu de perfis — aparece ao clicar em "Editar acesso" -->
            <VBox fx:id="submenuPerfil" spacing="0" minWidth="160"
                  visible="false" managed="false"
                  style="-fx-background-color: #ffffff;
                         -fx-border-color: #ddddcc;
                         -fx-border-width: 0 0 0 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 8, 0, 2, 0);">

                <Button text="Administrador" onAction="#handleSetAdministrador"
                        styleClass="perfil-item"/>
                <Button text="Organizador"   onAction="#handleSetOrganizador"
                        styleClass="perfil-item"/>
                <Button text="Árbitro"       onAction="#handleSetArbitro"
                        styleClass="perfil-item"/>
                <Button text="Operador"      onAction="#handleSetOperador"
                        styleClass="perfil-item"/>
            </VBox>

        </HBox>
    </center>

    <stylesheets>
        <String fx:value="/css/menu.css"/>
        <String fx:value="/css/gestao_usuarios.css"/>
    </stylesheets>

</BorderPane>
