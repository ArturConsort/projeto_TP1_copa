<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.GestaoUsuariosController"
            style="-fx-background-color: #0a0a0a;">

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d0d0d;
                     -fx-padding: 0 24 0 16;
                     -fx-min-height: 56;
                     -fx-border-color: transparent transparent #1e1a0a transparent;
                     -fx-border-width: 0 0 1 0;">

            <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                <image><Image url="@../images/worldcup_logo.png"/></image>
            </ImageView>

            <Region HBox.hgrow="NEVER" minWidth="20"/>

            <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelUsuarioLogado"
                   style="-fx-text-fill: #b0a898;
                          -fx-font-size: 12;
                          -fx-font-family: 'Segoe UI';"/>
            <Region minWidth="16"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #c9982a;
                           -fx-text-fill: #0a0a0a;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-font-family: 'Segoe UI';
                           -fx-background-radius: 14;
                           -fx-padding: 6 18 6 18;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CONTEÚDO PRINCIPAL ===== -->
    <center>
        <HBox spacing="0" style="-fx-padding: 28 32 28 32; -fx-background-color: #0a0a0a;">

            <!-- ========== COLUNA 1: BUSCA + LISTA ========== -->
            <VBox spacing="0" minWidth="220" maxWidth="220">

                <!-- Cabeçalho da coluna -->
                <Label text="USUÁRIOS"
                       style="-fx-text-fill: #c9982a;
                              -fx-font-size: 11;
                              -fx-font-weight: bold;
                              -fx-font-family: 'Segoe UI';
                              -fx-letter-spacing: 1.5;
                              -fx-padding: 0 0 12 0;"/>

                <!-- Filtro: Nome -->
                <TextField fx:id="campoBuscaNome"
                           promptText="Buscar por nome..."
                           onKeyReleased="#handleFiltrar"
                           styleClass="filtro-campo"/>

                <Region minHeight="6"/>

                <!-- Filtro: País -->
                <TextField fx:id="campoBuscaPais"
                           promptText="Buscar por país..."
                           onKeyReleased="#handleFiltrar"
                           styleClass="filtro-campo"/>

                <Region minHeight="6"/>

                <!-- Filtro: Login -->
                <TextField fx:id="campoBuscaLogin"
                           promptText="Buscar por login..."
                           onKeyReleased="#handleFiltrar"
                           styleClass="filtro-campo"/>

                <Region minHeight="6"/>

                <!-- Filtro: Acesso (dropdown) -->
                <ComboBox fx:id="comboBuscaAcesso"
                          promptText="Filtrar por acesso..."
                          onAction="#handleFiltrar"
                          maxWidth="Infinity"
                          styleClass="filtro-combo"/>

                <Region minHeight="12"/>

                <!-- Lista de usuários -->
                <ListView fx:id="listaUsuarios"
                          VBox.vgrow="ALWAYS"
                          styleClass="lista-usuarios"
                          style="-fx-pref-height: 420;"/>
            </VBox>

            <Region minWidth="24"/>

            <!-- ========== COLUNA 2: DADOS ATUAIS ========== -->
            <VBox fx:id="painelDados" spacing="0" minWidth="280" maxWidth="280"
                  visible="false" managed="false">

                <Label text="DADOS ATUAIS"
                       style="-fx-text-fill: #c9982a;
                              -fx-font-size: 11;
                              -fx-font-weight: bold;
                              -fx-font-family: 'Segoe UI';
                              -fx-letter-spacing: 1.5;
                              -fx-padding: 0 0 12 0;"/>

                <!-- Nome -->
                <Label text="Nome completo" styleClass="dado-label"/>
                <TextField fx:id="dadoNome" editable="false" styleClass="dado-campo"/>
                <Region minHeight="8"/>

                <!-- CPF -->
                <Label text="CPF" styleClass="dado-label"/>
                <TextField fx:id="dadoCpf" editable="false" styleClass="dado-campo"/>
                <Region minHeight="8"/>

                <!-- Email -->
                <Label text="E-mail" styleClass="dado-label"/>
                <TextField fx:id="dadoEmail" editable="false" styleClass="dado-campo"/>
                <Region minHeight="8"/>

                <!-- País -->
                <Label text="País" styleClass="dado-label"/>
                <TextField fx:id="dadoPais" editable="false" styleClass="dado-campo"/>
                <Region minHeight="8"/>

                <!-- Login -->
                <Label text="Login" styleClass="dado-label"/>
                <TextField fx:id="dadoLogin" editable="false" styleClass="dado-campo"/>
                <Region minHeight="8"/>

                <!-- Perfil -->
                <Label text="Perfil de acesso" styleClass="dado-label"/>
                <TextField fx:id="dadoPerfil" editable="false" styleClass="dado-campo"/>
                <Region minHeight="8"/>

                <!-- Senha -->
                <Label text="Senha" styleClass="dado-label"/>
                <TextField fx:id="dadoSenha" editable="false" styleClass="dado-campo"/>
            </VBox>

            <Region minWidth="24"/>

            <!-- ========== COLUNA 3: EDITAR DADOS ========== -->
            <VBox fx:id="painelEdicao" spacing="0" minWidth="280" maxWidth="280"
                  visible="false" managed="false">

                <Label text="EDITAR DADOS"
                       style="-fx-text-fill: #c9982a;
                              -fx-font-size: 11;
                              -fx-font-weight: bold;
                              -fx-font-family: 'Segoe UI';
                              -fx-letter-spacing: 1.5;
                              -fx-padding: 0 0 12 0;"/>

                <!-- Nome -->
                <Label text="Nome completo" styleClass="dado-label"/>
                <TextField fx:id="editNome" promptText="Nome completo" styleClass="edit-campo"/>
                <Region minHeight="8"/>

                <!-- CPF -->
                <Label text="CPF" styleClass="dado-label"/>
                <TextField fx:id="editCpf" promptText="000.000.000-00" styleClass="edit-campo"/>
                <Region minHeight="8"/>

                <!-- Email -->
                <Label text="E-mail" styleClass="dado-label"/>
                <TextField fx:id="editEmail" promptText="email@exemplo.com" styleClass="edit-campo"/>
                <Region minHeight="8"/>

                <!-- País -->
                <Label text="País" styleClass="dado-label"/>
                <TextField fx:id="editPais" promptText="País de origem" styleClass="edit-campo"/>
                <Region minHeight="8"/>

                <!-- Perfil de acesso -->
                <Label text="Perfil de acesso" styleClass="dado-label"/>
                <ComboBox fx:id="editPerfil"
                          promptText="Selecione o perfil"
                          maxWidth="Infinity"
                          styleClass="edit-combo"/>
                <Region minHeight="8"/>

                <!-- Senha -->
                <Label text="Senha" styleClass="dado-label"/>
                <TextField fx:id="editSenha" promptText="Mínimo 8 caracteres" styleClass="edit-campo"/>
                <Region minHeight="16"/>

                <!-- Mensagem de feedback -->
                <Label fx:id="labelFeedback" text="" wrapText="true"
                       style="-fx-font-size: 12;
                              -fx-font-family: 'Segoe UI';
                              -fx-padding: 0 0 10 0;"/>

                <!-- Botões -->
                <VBox spacing="10">
                    <Button text="salvar mudanças"
                            onAction="#handleSalvar"
                            maxWidth="Infinity"
                            styleClass="btn-salvar"/>

                    <Button text="EXCLUIR CONTA"
                            onAction="#handleExcluir"
                            maxWidth="Infinity"
                            styleClass="btn-excluir"/>
                </VBox>
            </VBox>

        </HBox>
    </center>

    <stylesheets>
        <String fx:value="/css/menu.css"/>
        <String fx:value="/css/gestao_usuarios.css"/>
    </stylesheets>

</BorderPane>
