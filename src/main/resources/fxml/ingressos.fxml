<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.IngressosController"
            style="-fx-background-color: radial-gradient(center 50% 60%, radius 70%, #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);">

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d0d0d;
                     -fx-padding: 0 24 0 16;
                     -fx-min-height: 56;
                     -fx-border-color: transparent transparent #1e1a0a transparent;
                     -fx-border-width: 0 0 1 0;">

            <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                <image><Image url="@../images/worldcup_logo.png"/></image>
            </ImageView>

            <Region HBox.hgrow="NEVER" minWidth="20"/>
            <Button text="← Voltar" onAction="#handleVoltar" styleClass="nav-btn"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelUsuarioLogado"
                   style="-fx-text-fill: #b0a898;
                          -fx-font-size: 12;
                          -fx-font-family: 'Segoe UI';"/>
            <Region minWidth="16"/>
            <Button text="Sair" onAction="#handleLogout"
                    style="-fx-background-color: #c9982a;
                           -fx-text-fill: #0a0a0a;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-font-family: 'Segoe UI';
                           -fx-background-radius: 14;
                           -fx-padding: 6 18 6 18;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CONTEÚDO ===== -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">

            <VBox spacing="20" alignment="TOP_CENTER"
                  style="-fx-background-color: transparent;">

                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <Label text="Comprar Ingressos" styleClass="sel-titulo-v3"/>

                <!-- BARRA DE PESQUISA -->
                <HBox alignment="CENTER" styleClass="filtro-box">
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="10" alignment="CENTER">
                        <TextField fx:id="campoBusca"
                                   promptText="🔍  Buscar por time, data ou estádio..."
                                   prefWidth="400"
                                   styleClass="campo-texto"/>
                        <Button text="Buscar"
                                onAction="#aoBuscar"
                                styleClass="sel-btn-consulta-v3"
                                prefHeight="36"/>
                        <Button text="Limpar"
                                onAction="#aoLimparBusca"
                                styleClass="sel-btn-consulta-v3"
                                prefHeight="36"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🎟 Meus Ingressos"
                            onAction="#irMeusIngressos"
                            styleClass="sel-btn-cadastro-v3"
                            prefHeight="36"/>
                </HBox>

                <!-- GRADE DE PARTIDAS -->
                <FlowPane fx:id="painelPartidas"
                          hgap="24"
                          vgap="24"
                          alignment="CENTER"/>

            </VBox>

        </ScrollPane>
    </center>

    <stylesheets>
        <String fx:value="/css/menu.css"/>
        <String fx:value="/css/selecao_inicio.css"/>
        <String fx:value="/css/ingressos.css"/>
    </stylesheets>

</BorderPane>
