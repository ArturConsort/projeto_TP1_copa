<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllersJavaFX.IngressosController"
      prefWidth="1200"
      prefHeight="700"
      styleClass="sel-root-v3">

    <style>
        -fx-background-color: radial-gradient(center 50% 60%, radius 70%,
        #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);
    </style>

    <!-- HUD -->

    <HBox styleClass="hud-bar" alignment="CENTER_LEFT">

        <ImageView fitHeight="48"
                   fitWidth="48"
                   preserveRatio="true">
            <image>
                <Image url="@/images/worldcup_logo.png"/>
            </image>
            <HBox.margin>
                <Insets right="24"/>
            </HBox.margin>
        </ImageView>

        <Button fx:id="btnHome"      text="Home"      onAction="#irHome"      styleClass="nav-btn"/>
        <Button fx:id="btnJogadores" text="Jogadores" onAction="#irJogadores" styleClass="nav-btn"/>
        <Button fx:id="btnEquipes"   text="Equipes"   onAction="#irEquipes"   styleClass="nav-btn"/>
        <Button fx:id="btnPartidas"  text="Partidas"  onAction="#irPartidas"  styleClass="nav-btn"/>
        <Button fx:id="btnEstadios"  text="Estádios"  onAction="#irEstadios"  styleClass="nav-btn"/>
        <Button fx:id="btnArbitros"  text="Árbitros"  onAction="#irArbitros"  styleClass="nav-btn"/>
        <Button fx:id="btnIngressos" text="Ingressos" onAction="#irIngressos" styleClass="nav-btn nav-btn-active"/>

        <Region HBox.hgrow="ALWAYS"/>

    </HBox>

    <!-- CORPO -->

    <ScrollPane VBox.vgrow="ALWAYS"
                fitToWidth="true"
                styleClass="ingressos-scroll">

        <VBox spacing="20"
              alignment="TOP_CENTER">

            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <Label text="Comprar Ingressos"
                   styleClass="sel-titulo-v3"/>

            <!-- BARRA DE PESQUISA -->
            <HBox alignment="CENTER" styleClass="filtro-box">
                <!-- Espaço à esquerda (espelha o largura do botão Meus Ingressos) -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Grupo central: campo + botões -->
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="campoBusca"
                               promptText="🔍  Buscar por time, data ou estádio..."
                               prefWidth="400"
                               styleClass="campo-texto"/>
                    <Button text="Buscar"
                            onAction="#aoBuscar"
                            styleClass="sel-btn-consulta-v3"
                            prefHeight="36"/>
                    <Button text="Limpar"
                            onAction="#aoLimparBusca"
                            styleClass="sel-btn-consulta-v3"
                            prefHeight="36"/>
                </HBox>

                <!-- Espaço à direita + botão ancorado -->
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🎟 Meus Ingressos"
                        onAction="#irMeusIngressos"
                        styleClass="sel-btn-cadastro-v3"
                        prefHeight="36"/>
            </HBox>

            <!-- GRADE DE PARTIDAS -->

            <FlowPane fx:id="painelPartidas"
                      hgap="24"
                      vgap="24"
                      alignment="CENTER">

                <!-- os cards de partida sao adicionados dinamicamente pelo controller -->

            </FlowPane>

        </VBox>

    </ScrollPane>

    <stylesheets>
        <String fx:value="/css/selecao_inicio.css"/>
        <String fx:value="/css/ingressos.css"/>
    </stylesheets>

</VBox>
