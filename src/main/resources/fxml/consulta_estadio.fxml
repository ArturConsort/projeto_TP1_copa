<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.ConsultaEstadioController"
            prefWidth="900"
            prefHeight="680"
            styleClass="root">

    <VBox alignment="TOP_CENTER"
          spacing="20"
          AnchorPane.topAnchor="20"
          AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20">

        <ImageView fitWidth="70" fitHeight="70" preserveRatio="true">
            <image><Image url="@/images/worldcup_logo.png"/></image>
        </ImageView>

        <VBox spacing="16" styleClass="card">

            <Label text="Consulta de Estádios" styleClass="titulo"/>

            <!-- FILTROS -->
            <GridPane hgap="15" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <Label text="Nome do estádio" styleClass="label"/>
                    <TextField fx:id="campoNomeEstadio"
                               promptText="Buscar por nome"
                               maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <Label text="Cidade" styleClass="label"/>
                    <TextField fx:id="campoCidade"
                               promptText="Filtrar por cidade"
                               maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="0">
                    <Label text="Estado (UF)" styleClass="label"/>
                    <TextField fx:id="campoEstado"
                               promptText="Ex.: SP, RJ, MG"
                               maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <Label text="Tipo de gramado" styleClass="label"/>
                    <ComboBox fx:id="comboGramado"
                              promptText="Selecione o tipo de gramado"
                              maxWidth="Infinity"/>
                </VBox>

            </GridPane>

            <!-- BOTÕES DE AÇÃO -->
            <HBox spacing="12">
                <Button text="Pesquisar" onAction="#handlePesquisar" styleClass="btn-cadastrar"/>
                <Button text="Limpar"    onAction="#handleLimpar"    styleClass="btn-voltar"/>
                <Button text="Excluir"   onAction="#handleExcluir"   styleClass="btn-excluir"/>
            </HBox>

            <!-- TABELA -->
            <TableView fx:id="tabelaEstadios"
                       prefHeight="280"
                       maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colNome"        text="Nome"        prefWidth="200"/>
                    <TableColumn fx:id="colCidade"      text="Cidade"      prefWidth="150"/>
                    <TableColumn fx:id="colEstado"      text="Estado"      prefWidth="80"/>
                    <TableColumn fx:id="colCapacidade"  text="Capacidade"  prefWidth="110"/>
                    <TableColumn fx:id="colTipoGramado" text="Gramado"     prefWidth="110"/>
                </columns>
                <placeholder>
                    <Label text="Nenhum estádio encontrado."/>
                </placeholder>
            </TableView>

            <!-- RODAPÉ -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="labelTotal" styleClass="label"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Atualizar"
                        onAction="#handleAtualizar"
                        styleClass="btn-voltar"/>
                <Button fx:id="btnVoltar"
                        text="Voltar"
                        onAction="#handleVoltar"
                        styleClass="btn-excluir"/>
            </HBox>

        </VBox>
    </VBox>

    <stylesheets>
        <String fx:value="/css/cadastro_partida.css"/>
    </stylesheets>

</AnchorPane>