<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllersJavaFX.ConsultaDesignacaoController"
            prefWidth="900"
            prefHeight="680"
            styleClass="root">

    <VBox alignment="TOP_CENTER"
          spacing="20"
          AnchorPane.topAnchor="20"
          AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20">

        <ImageView fitWidth="70" fitHeight="70" preserveRatio="true">
            <image><Image url="@/images/worldcup_logo.png"/></image>
        </ImageView>

        <VBox spacing="16" styleClass="card">

            <Label text="Consulta de Designações" styleClass="titulo"/>

            <GridPane hgap="15" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <Label text="Partida" styleClass="label"/>
                    <TextField fx:id="campoPartida"
                               promptText="Buscar por partida"
                               maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <Label text="Árbitro Principal" styleClass="label"/>
                    <TextField fx:id="campoArbitro"
                               promptText="Buscar por árbitro"
                               maxWidth="Infinity"/>
                </VBox>

            </GridPane>

            <HBox spacing="12">
                <Button text="Pesquisar" onAction="#handlePesquisar" styleClass="btn-cadastrar"/>
                <Button text="Limpar"    onAction="#handleLimpar"    styleClass="btn-voltar"/>
                <Button text="Excluir"   onAction="#handleExcluir"   styleClass="btn-excluir"/>
            </HBox>

            <TableView fx:id="tabelaDesignacoes"
                       prefHeight="280"
                       maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colPartida"          text="Partida"           prefWidth="220"/>
                    <TableColumn fx:id="colArbitroPrincipal" text="Árbitro Principal" prefWidth="160"/>
                    <TableColumn fx:id="colAssistente1"      text="Assistente 1"      prefWidth="140"/>
                    <TableColumn fx:id="colAssistente2"      text="Assistente 2"      prefWidth="140"/>
                </columns>
                <placeholder>
                    <Label text="Nenhuma designação encontrada."/>
                </placeholder>
            </TableView>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="labelTotal" styleClass="label"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Atualizar" onAction="#handleAtualizar" styleClass="btn-voltar"/>
                <Button fx:id="btnVoltar" text="Voltar" onAction="#handleVoltar" styleClass="btn-excluir"/>
            </HBox>

        </VBox>
    </VBox>

    <stylesheets>
        <String fx:value="/css/cadastro_partida.css"/>
    </stylesheets>

</AnchorPane>