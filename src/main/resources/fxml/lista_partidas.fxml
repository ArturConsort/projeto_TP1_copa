<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllersJavaFX.ListaPartidasController"
      prefWidth="1400"
      prefHeight="700">

    <style>
        -fx-background-color: radial-gradient(center 50% 60%, radius 70%,
        #3d2e0a 0%, #1a1508 45%, #0a0a0a 100%);
    </style>

    <VBox VBox.vgrow="ALWAYS" spacing="16" alignment="TOP_CENTER">
        <padding><Insets top="30" right="40" bottom="20" left="40"/></padding>

        <Label text="Consulta de Partidas" styleClass="sel-titulo-v3"/>

        <!-- FILTROS -->
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filtro-box">
            <Label text="Time"/>
            <TextField fx:id="campoBuscarTime" promptText="Nome do time" prefWidth="180"/>
            <Label text="Fase"/>
            <ComboBox fx:id="comboBuscarFase" promptText="Fase" prefWidth="150"/>
            <Label text="Data"/>
            <TextField fx:id="campoBuscarData" promptText="dd/mm/aaaa" prefWidth="130"/>
            <Button text="Pesquisar" onAction="#aoBuscar" styleClass="sel-btn-cadastro-v3"/>
            <Button text="Limpar"    onAction="#aoLimpar" styleClass="sel-btn-consulta-v3"/>
        </HBox>

        <!-- TABELA DE PARTIDAS PENDENTES/EM ANDAMENTO -->
        <Label text="Partidas" styleClass="sel-titulo-v3"
               style="-fx-font-size: 15; -fx-text-fill: #d4af37;"/>

        <TableView fx:id="tabelaPartidas" VBox.vgrow="ALWAYS" styleClass="tabela-partidas">
            <columns>
                <TableColumn fx:id="colNumero"    text="Nº"        prefWidth="45"/>
                <TableColumn fx:id="colTimeCasa"  text="Time Casa" prefWidth="130"/>
                <TableColumn fx:id="colVisitante" text="Visitante" prefWidth="130"/>
                <TableColumn fx:id="colEstadio"   text="Estádio"   prefWidth="130"/>
                <TableColumn fx:id="colData"      text="Data"      prefWidth="100"/>
                <TableColumn fx:id="colHorario"   text="Horário"   prefWidth="75"/>
                <TableColumn fx:id="colFase"      text="Fase"      prefWidth="140"/>
                <TableColumn fx:id="colStatus"    text="Status"    prefWidth="110"/>
                <TableColumn fx:id="colStatus2"   text="Mudar Status" prefWidth="130"/>
                <TableColumn fx:id="colAcoes"     text="Ações"     prefWidth="160"/>
            </columns>
        </TableView>

        <!-- TABELA DE RESULTADOS FINALIZADOS -->
        <Label text="Resultados Finalizados" styleClass="sel-titulo-v3"
               style="-fx-font-size: 15; -fx-text-fill: #d4af37;"/>

        <TableView fx:id="tabelaResultados" VBox.vgrow="ALWAYS" styleClass="tabela-partidas">
            <columns>
                <TableColumn fx:id="rColPartida"   text="Partida"           prefWidth="70"/>
                <TableColumn fx:id="rColVencedor"  text="Vencedor"          prefWidth="150"/>
                <TableColumn fx:id="rColPerdedor"  text="Perdedor"          prefWidth="150"/>
                <TableColumn fx:id="rColPlacar"    text="Placar"            prefWidth="100"/>
                <TableColumn fx:id="rColPenaltis"  text="Pênaltis"          prefWidth="100"/>
                <TableColumn fx:id="rColAmarelos"  text="Cartões Amarelos"  prefWidth="140"/>
                <TableColumn fx:id="rColVermelhos" text="Cartões Vermelhos" prefWidth="150"/>
                <TableColumn fx:id="rColFase"      text="Fase"              prefWidth="140"/>
            </columns>
        </TableView>

        <!-- RODAPÉ -->
        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Label fx:id="labelTotal"/>
            <Button text="Atualizar" onAction="#aoAtualizar" styleClass="sel-btn-cadastro-v3"/>
            <Button text="Voltar"    onAction="#aoVoltar"    styleClass="sel-btn-consulta-v3"/>
        </HBox>

    </VBox>

    <stylesheets>
        <String fx:value="/css/consulta_partida.css"/>
    </stylesheets>

</VBox>
